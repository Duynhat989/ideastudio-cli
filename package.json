{
  "name": "IdeaStudio",
  "version": "2.1.26",
  "description": "",
  "main": "index.js",
  "scripts": {
    "prebuild": "rimraf dist",
    "version:bump": "node scripts/bump-version.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "chcp 65001 | electron . --dev",
    "build": "npm run version:bump && electron-builder --win --mac --linux",
    "build:win": "npm run version:bump && electron-builder --win nsis --x64",
    "build:mac": "npm run version:bump && electron-builder --mac dmg zip",
    "build:linux": "npm run version:bump && electron-builder --linux AppImage deb",
    "build:all": "npm run version:bump && electron-builder -mwl",
    "dist": "npm run build:win"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fingerprint-generator": "^2.1.70",
    "fingerprint-injector": "^2.1.56",
    "form-data": "^4.0.3",
    "multer": "^1.4.5-lts.1",
    "uuid": "^8.3.2"
  },
  "build": {
    "appId": "com.ideastudio.app",
    "productName": "IdeaStudio",
    "files": [
      "**/*",
      "!dist/**",
      "!metadata/**"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/ffprobe-static/**"
    ],
    "extraResources": [],
    "win": {
      "icon": "src/assets/logo.ico",
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.video"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Video"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "src/assets/logo.ico",
      "uninstallerIcon": "src/assets/logo.ico",
      "include": "build/installer.nsh"
    }
  }
}
